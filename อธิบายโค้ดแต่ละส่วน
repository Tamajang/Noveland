### **pages/Search.tsx** - หน้าค้นหา
**หน้าที่:** ค้นหาและกรองนิยาย

```typescript
export default function Search() {
  const [query, setQuery] = useState('');
  const [category, setCategory] = useState('');
  const [status, setStatus] = useState('');
  const [sortBy, setSortBy] = useState('views');

  // กรองนิยาย
  let results = novels.filter(novel => {
    const matchQuery = novel.title.toLowerCase().includes(query.toLowerCase());
    const matchCategory = !category || novel.category === category;
    const matchStatus = !status || novel.status === status;
    return matchQuery && matchCategory && matchStatus;
  });

  // เรียงลำดับ
  if (sortBy === 'views') {
    results.sort((a, b) => b.views - a.views);
  } else if (sortBy === 'rating') {
    results.sort((a, b) => b.rating - a.rating);
  }

  return (
    <div className="search-page">
      <h1>ค้นหานิยาย</h1>

      <div className="search-filters">
        <input
          type="text"
          placeholder="ค้นหาชื่อนิยาย..."
          value={query}
          onChange={(e) => setQuery(e.target.value)}
        />

        <select value={category} onChange={(e) => setCategory(e.target.value)}>
          <option value="">ทั้งหมด</option>
          {categories.map(cat => (
            <option key={cat.id} value={cat.name}>{cat.name}</option>
          ))}
        </select>

        <select value={status} onChange={(e) => setStatus(e.target.value)}>
          <option value="">ทั้งหมด</option>
          <option value="กำลังดำเนินการ">กำลังดำเนินการ</option>
          <option value="จบแล้ว">จบแล้ว</option>
        </select>

        <select value={sortBy} onChange={(e) => setSortBy(e.target.value)}>
          <option value="views">ยอดนิยม</option>
          <option value="rating">คะแนนสูง</option>
        </select>
      </div>

      <div className="novel-grid">
        {results.map(novel => (
          <NovelCard key={novel.id} novel={novel} />
        ))}
      </div>
    </div>
  );
}
```

**ความสำคัญ:**
- ใช้ `filter()` เพื่อค้นหาตามคำค้นหา หมวดหมู่ สถานะ
- ใช้ `sort()` เพื่อเรียงลำดับ
- State ทั้งหมดอัปเดตแบบ Real-time

