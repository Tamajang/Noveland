## 📊 ตัวอย่าง OKLCH ใน NoveLand

### Dark Mode Colors:

```css
:root {
  /* พื้นหลัง */
  --background: oklch(0.09 0.005 285);
  /* L=0.09 (ดำเข้ม 9%)
     C=0.005 (ไม่มีสี)
     H=285 (สีม่วงเบา) */

  /* ข้อความ */
  --foreground: oklch(0.95 0.005 285);
  /* L=0.95 (ขาวสว่าง 95%)
     C=0.005 (ไม่มีสี)
     H=285 (สีม่วงเบา) */

  /* Card */
  --card: oklch(0.12 0.005 285);
  /* L=0.12 (ดำเล็กน้อย 12%)
     C=0.005 (ไม่มีสี)
     H=285 (สีม่วงเบา) */

  /* สีหลัก (น้ำเงิน) */
  --primary: oklch(0.55 0.22 264);
  /* L=0.55 (กลาง 55%)
     C=0.22 (สีเข้ม)
     H=264 (สีน้ำเงิน) */

  /* ขอบ */
  --border: oklch(1 0 0 / 10%);
  /* L=1 (ขาวสว่าง)
     C=0 (ไม่มีสี)
     H=0 (ไม่สำคัญ)
     A=10% (โปร่ง 90%) */
}
```

### Light Mode Colors:

```css
body[data-theme="light"] {
  /* พื้นหลัง */
  --background: oklch(0.98 0.002 240);
  /* L=0.98 (ขาวสว่างมาก 98%)
     C=0.002 (ไม่มีสี)
     H=240 (สีน้ำเงินเบา) */

  /* ข้อความ */
  --foreground: oklch(0.15 0.01 260);
  /* L=0.15 (ดำเข้ม 15%)
     C=0.01 (ไม่มีสี)
     H=260 (สีน้ำเงินเบา) */

  /* Card */
  --card: oklch(1 0 0);
  /* L=1 (ขาวบริสุทธิ์)
     C=0 (ไม่มีสี)
     H=0 (ไม่สำคัญ) */

  /* ขอบ */
  --border: oklch(0.15 0 0 / 15%);
  /* L=0.15 (ดำ)
     C=0 (ไม่มีสี)
     H=0 (ไม่สำคัญ)
     A=15% (โปร่ง 85%) */
}
```

